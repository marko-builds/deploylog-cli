{
  "name": "deploylog",
  "version": "0.2.2",
  "description": "Push changelog entries from the terminal",
  "type": "module",
  "bin": {
    "deploylog": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "changelog",
    "deploylog",
    "cli",
    "release-notes",
    "devtools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marko-builds/deploylog-cli.git"
  },
  "homepage": "https://deploylog.dev",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
